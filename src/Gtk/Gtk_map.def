#ifdef gtk_fun_doc

/*
           ╔═══════════════════════════════════════════════════════════════════════════════════════════════════════════════════╗
           ║                                                    Macro Argument                                                 ║
           ║══════════════╤═══════════════╤════════════════╤══════════╤═══╤════════════════════════════════════════════════════╣
           ║    widget    │               │                │    APL   │Typ│                                                    ║
           ║    prefix    │   gtk_class   │  gtk_function  │ Variable │Z│A│                          help                      ║
           ╠══════════════╪═══════════════╪════════════════╪══════════╪═╪═╪════════════════════════════════════════════════════╣
 *///      ║              │               │                │          │ │ │                                                    ║
gtk_fun_doc(entry         ,GtkEntry       ,set_text        ,Text      ,V,S, set the text in e.g. a text entry                  )
gtk_fun_doc(entry         ,GtkEntry       ,get_text        ,Text      ,S,V, return the text in e.g. a text entry               )
gtk_fun_doc(label         ,GtkLabel       ,set_label       ,Text      ,V,S, set the text of e.g. a label                       )
gtk_fun_doc(progress_bar  ,GtkProgressBar ,set_fraction    ,Fraction  ,V,F, set the progress shown by a progress bar           )
gtk_fun_doc(progress_bar  ,GtkProgressBar ,get_fraction    ,Fraction  ,F,V, return the progress shown by a progress bar        )
gtk_fun_doc(level_bar     ,GtkLevelBar    ,set_value       ,Level     ,V,F, set the level shown by a level bar                 )
gtk_fun_doc(level_bar     ,GtkLevelBar    ,get_value       ,Level     ,F,V, return the level  shown by level bar               )
gtk_fun_doc(combo_box     ,GtkComboBox    ,set_active      ,Selected  ,V,I, set the selected item of a combo box (-1 for none) )
gtk_fun_doc(combo_box     ,GtkComboBox    ,get_active      ,Selected  ,I,V, return the selected item of a combo box (-1 = none))
gtk_fun_doc(drawingarea   ,GtkDrawingArea ,draw_commands   ,DrawCmd   ,V,S, set the commands needed to draw a drawing area     )
gtk_fun_doc(drawingarea   ,GtkDrawingArea ,set_area_size   ,SX_SY     ,V,I, set the area size to SX_SY >> 16 : SX_SY & 0xFFFF  )
gtk_fun_doc(drawingarea   ,GtkDrawingArea ,set_Y_origin    ,Origin    ,V,I, set the Y-origin to the top (1) or the bottom (0)  )
gtk_fun_doc(combo_box_text,GtkComboBoxText,get_active_text ,Selected  ,S,V, return the selected text in a combo box text       )
gtk_fun_doc(spin_button   ,GtkSpinButton  ,get_value       ,Selected  ,F,V, return the current value                           )
gtk_fun_doc(spin_button   ,GtkSpinButton  ,get_value_as_int,Selected  ,I,V, return the current value                           )
gtk_fun_doc(text_view     ,GtkTextView    ,add_row         ,Text      ,V,S, add a row to a text view                           )
//         ║              │               │                │          │ │ │                                                    ║
//         ╚══════════════╧═══════════════╧════════════════╧══════════╧═╧═╧════════════════════════════════════════════════════╝

#undef gtk_fun_doc
#endif

#ifdef gtk_event_def
/* a mapping from GTK events (signals) to Gtk_server callbacks...

             ╔═════════════════════════════════════════════════════════════════════════════════════════════════════╗
             ║                                       Macro Argument                                                ║
╔════════════╬══════════════════════╤═════╤════════╤══════════════╤═════════════════╤═════════════╤════════════════╣
║            ║                      │ arg │optional│     event    │   widget name   │   glade_ID  │       Gtk      ║
║ Used By    ║ ev_name              │count│  args  │   signature  │    (example)    │    prefix   │      class     ║
╠════════════╬══════════════════════╪═════╪════════╪══════════════╪═════════════════╪═════════════╪════════════════╣
║ Quad_GTK   ║    ✓                 │     │        │              │                 │             │                ║
║ Gtk_server ║    ✓                 │     │   ✓    │      ✓       │                 │             │                ║
║ asciidoc   ║    ✓                 │  ✓  │   ✓    │      ✓       │       ✓         │      ✓      │       ✓        ║
╚════════════╬══════════════════════╪═════╪════════╪══════════════╪═════════════════╪═════════════╪════════════════╣
 *///        ║                      │     │        │              │                 │             │                ║
gtk_event_def( draw                 ,  1  ,        ,HiNsEsIsCs    , Canvas          , drawingarea , GtkDrawingArea )
gtk_event_def( destroy              ,  1  ,        ,HiNsEsIsCs    , Main-Window     , window      , GtkWindow      )
gtk_event_def( row_selected         ,  1  ,        ,HiNsEsXiYiBiLi, text_view-Mouse , text_view   , GtkTextView    )
gtk_event_def( clicked              ,  1  ,        ,HiNsEsIsCs    , OK-button       , button      , GtkButton      )
gtk_event_def( changed              ,  1  ,        ,HiNsEsIsCs    , Select-box      , combobox    , GtkComboBox    )
gtk_event_def( check_resize         ,  1  ,        ,HiNsEsIsCs    , -               , -           , GtkContainer   )
gtk_event_def( activate             ,  1  ,        ,HiNsEsIsCs    , Text-entry      , entry       , GtkEntry       )
gtk_event_def( backspace            ,  1  ,        ,HiNsEsIsCs    , -               , entry       , GtkEntry       )
gtk_event_def( cut_clipboard        ,  1  ,        ,HiNsEsIsCs    , -               , entry       , GtkEntry       )
gtk_event_def( copy_clipboard       ,  1  ,        ,HiNsEsIsCs    , -               , entry       , GtkEntry       )
gtk_event_def( paste_clipboard      ,  1  ,        ,HiNsEsIsCs    , -               , entry       , GtkEntry       )
gtk_event_def( toggle_overwrite     ,  1  ,        ,HiNsEsIsCs    , -               , entry       , GtkEntry       )
gtk_event_def( activate_cursor_row  ,  1  ,        ,HiNsEsIsCs    , -               , listbox     , GtkListBox     )
gtk_event_def( toggle_cursor_row    ,  1  ,        ,HiNsEsIsCs    , -               , listbox     , GtkListBox     )
gtk_event_def( selected_rows_changed,  1  ,        ,HiNsEsIsCs    , -               , listbox     , GtkListBox     )
gtk_event_def( select_all           ,  1  ,        ,HiNsEsIsCs    , -               , listbox     , GtkListBox     )
gtk_event_def( unselect_all         ,  1  ,        ,HiNsEsIsCs    , -               , listbox     , GtkListBox     )
gtk_event_def( toggled              ,  1  ,        ,HiNsEsIsCs    , -               , -           , GtkToggleToolButton)
gtk_event_def( show                 ,  1  ,        ,HiNsEsIsCs    , -               , -           , GtkWidget      )
gtk_event_def( hide                 ,  1  ,        ,HiNsEsIsCs    , -               , -           , GtkWidget      )
gtk_event_def( map                  ,  1  ,        ,HiNsEsIsCs    , -               , -           , GtkWidget      )
gtk_event_def( unmap                ,  1  ,        ,HiNsEsIsCs    , -               , -           , GtkWidget      )

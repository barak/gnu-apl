gtk_event_def( unrealize            ,  1  ,        ,HiNsEsIsCs    , -               , -           , GtkWidget      )
gtk_event_def( composited_changed   ,  1  ,        ,HiNsEsIsCs    , -               , -           , GtkWidget      )
gtk_event_def( style_updated        ,  1  ,        ,HiNsEsIsCs    , -               , -           , GtkWidget      )

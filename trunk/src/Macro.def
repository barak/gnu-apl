/// \cond NOPE

/// monadic EACH without result
//
mac_def(LO_EACH_B,
 "(LO LO_EACH_B) B;N;N_max\n"
 u8"N‚Üź‚éēIO ‚óä N_max‚ÜźN+‚ćīB‚Üź,B\n"
 u8"LO N‚äÉB ‚óä 0 ‚Üí N_max>N‚ÜźN+1\n")

/// dyadic EACH without result, scalar A, scalar B
//
mac_def(sA_LO_EACH_sB,
 "A (LO sa_LO_EACH_sB) B\n"
 "A LO B\n")

/// dyadic EACH without result, scalar A, vector B
//
mac_def(sA_LO_EACH_vB,
 "A (LO sa_LO_EACH_vB) B;N;N_max\n"
 u8"N‚Üź‚éēIO ‚óä N_max‚ÜźN+‚ćīB‚Üź,B\n"
 u8"(‚äÉA) LO N‚äÉB ‚óä 0 ‚Üí N_max>N‚ÜźN+1\n")

/// dyadic EACH without result, vector A, scalar B
//
mac_def(vA_LO_EACH_sB,
 "A (LO vA_LO_EACH_sB) B;N;N_max\n"
 u8"N‚Üź‚éēIO ‚óä N_max‚ÜźN+‚ćīA‚Üź,A\n"
 u8"(N‚äÉA) LO ‚äÉB ‚óä 0 ‚Üí N_max>N‚ÜźN+1\n")

/// dyadic EACH without result, vector A, vector B
//
mac_def(vA_LO_EACH_vB,
 "A (LO vA_LO_EACH_vB) B;N;N_max\n"
 u8"N‚Üź‚éēIO ‚óä A‚Üź,A ‚óä N_max‚ÜźN+‚ćīB‚Üź,B\n"
 u8"(N‚äÉA) LO N‚äÉB ‚óä 0 ‚Üí N_max>N‚ÜźN+1\n")

/// monadic EACH with result
//
mac_def(Z__LO_EACH_B, 
 u8"Z‚Üź(LO Z__LO_EACH_B) B;rho_Z;N;N_max\n"
 u8"rho_Z‚Üź‚ćīB ‚óä N‚Üź‚éēIO ‚óä N_max‚ÜźN+‚ćīB‚Üź,B ‚óä Z‚ÜźN_max‚ćī0\n"
 u8"(N‚äÉZ)‚ÜźLO N‚äÉB ‚óä 0 ‚Üí N_max>N‚ÜźN+1\n"
 u8"Z‚Üźrho_Z‚ćīZ\n")

/// dyadic EACH with result, scalar A, scalar B
//
mac_def(Z__sA_LO_EACH_sB,
 u8"Z‚ÜźA (LO Z__sA_LO_EACH_sB) B\n"
 u8"Z‚Üź‚äāA LO B\n")

/// dyadic EACH with result, scalar A, vector B
//
mac_def(  Z__sA_LO_EACH_vB, 
 u8"Z‚ÜźA (LO Z__sA_LO_EACH_vB) B;rho_Z;N;N_max\n"
 u8"rho_Z‚Üź‚ćīB ‚óä N‚Üź‚éēIO ‚óä N_max‚ÜźN+‚ćīB‚Üź,B ‚óä Z‚ÜźN_max‚ćī0\n"
 u8"(N‚äÉZ)‚Üź‚äā(‚äÉA) LO N‚äÉB ‚óä 0 ‚Üí N_max>N‚ÜźN+1\n"
 u8"Z‚Üźrho_Z‚ćīZ\n")

/// dyadic EACH with result, vector A, scalar B
//
mac_def(  Z__vA_LO_EACH_sB, 
 u8"Z‚ÜźA (LO Z__vA_LO_EACH_sB) B;rho_Z;N;N_max\n"
 u8"rho_Z‚Üź‚ćīA ‚óä N‚Üź‚éēIO ‚óä N_max‚ÜźN+‚ćīA‚Üź,A ‚óä Z‚ÜźN_max‚ćī0\n"
 u8"(N‚äÉZ)‚Üź‚äā(N‚äÉA) LO ‚äÉB ‚óä 0 ‚Üí N_max>N‚ÜźN+1\n"
 u8"Z‚Üźrho_Z‚ćīZ\n")

/// dyadic EACH with result, vector A, vector B
//
mac_def(  Z__vA_LO_EACH_vB,
 u8"Z‚ÜźA (LO Z__vA_LO_EACH_vB) B;rho_Z;N;N_max\n"
 u8"‚Üí((‚ćīA)‚Č°‚ćīB)‚ćīSHAPES_MATCH ‚óä ‚éēES 5,2+(‚ćī‚ćīA)=‚ćī‚ćīB\n"
 u8"SHAPES_MATCH: rho_Z‚Üź‚ćīB ‚óä N‚Üź‚éēIO ‚óä A‚Üź,A ‚óä N_max‚ÜźN+‚ćīB‚Üź,B ‚óä Z‚ÜźN_max‚ćī0\n"
 u8"(N‚äÉZ)‚Üź(N‚äÉA) LO N‚äÉB ‚óä 0 ‚Üí N_max>N‚ÜźN+1\n"
 u8"Z‚Üźrho_Z‚ćīZ\n")

/// outer product
//
mac_def(  Z__A_LO_OUTER_B,
 u8"Z‚ÜźA (LO Z__A_LO_OUTER_B) B;rho_Z;N;N_max;I;IA;IB\n"
 u8"rho_Z‚Üź(‚ćīA),‚ćīB ‚óä N‚Üź‚éēIO ‚óä A‚Üź,A ‚óä B‚Üź,B ‚óä I‚Üź,‚ć≥(‚ćīA),‚ćīB ‚óä N_max‚ÜźN+‚ćīI ‚óä Z‚ÜźN_max‚ćī0\n"
 u8"(IA IB)‚Üź‚äÉI[N] ‚óä Z[N]‚Üź‚äā(‚äÉA[IA]) LO ‚äÉB[IB] ‚óä 0 ‚Üí N_max>N‚ÜźN+1\n"
 u8"Z‚Üźrho_Z‚ćīZ\n")

/// inner product. caller has checked that the shapes of A and B fit
//
mac_def(  Z__A_LO_INNER_RO_B,
 u8"Z‚ÜźA (LO INNER RO) B;‚éēIO\n"
 u8"    ‚éēIO‚Üź1 ‚óä ‚Üí (‚ćī‚ćīA) ‚Üď sA ‚óä ‚Üí (‚ćī‚ćīB) ‚Üď vA_sB\n"
 u8"vA_vB: Z‚ÜźLO/¬® (‚äā[ŌĀŌĀA]A) ‚ąė.RO ‚äā[1]B ‚óä ‚Üí0\n"
 u8"vA_sB: Z‚ÜźLO/¬® (‚äā[ŌĀŌĀA]A) ‚ąė.RO ‚äāB    ‚óä ‚Üí0\n"
 u8"sA: ‚Üí (‚ćī‚ćīB) ‚Üď sA_sB\n"
 u8"sA_vB: Z‚ÜźLO/¬® (‚äāA)      ‚ąė.RO ‚äā[1]B ‚óä ‚Üí0\n"
 u8"sA_sB: Z‚ÜźLO/¬® (‚äāA)      ‚ąė.RO ‚äāB    ‚óä ‚Üí0\n")

/// monadic power with repeat count and no result
//
mac_def(  LO_POWER_N_B,
  " A (LO LO_POWER_N_B N) Z\n"
u8"LO Z ‚óä 0 ‚Üí 0<N‚ÜźN-1\n")

/// dyadic power with repeat count and no result
//
mac_def(  A_LO_POWER_N_B,
  " A (LO A_LO_POWER_N_B N) Z\n"
u8"A LO Z ‚óä 0 ‚Üí 0<N‚ÜźN-1\n")

/// monadic power with repeat count and result
//
mac_def(  Z__LO_POWER_N_B,
u8" Z‚ÜźA (LO Z__LO_POWER_N_B N) Z\n"
u8" Z‚ÜźLO Z ‚óä 0 ‚Üí 0<N‚ÜźN-1\n")

/// dyadic power with repeat count and result
//
mac_def(  Z__A_LO_POWER_N_B,
u8" Z‚ÜźA (LO Z__A_LO_POWER_N_B N) Z\n"
u8"Z‚ÜźA LO Z ‚óä 0 ‚Üí 0<N‚ÜźN-1\n")

/// monadic power with condition function RO and no result
//
mac_def(  Z__LO_POWER_RO_B,
  u8" Z‚Üź(LO Z__LO_POWER_RO_B RO) B;T\n"
u8"Z‚ÜźLO B ‚óä T‚ÜźZ RO B ‚óä B‚ÜźZ ‚óä 0 ‚Üí(,T)‚ČĘ,1\n")

/// monadic power with condition function RO and result
//
mac_def(  Z__A_LO_POWER_RO_B,
u8" Z‚ÜźA (LO Z__A_LO_POWER_RO_B RO) B;T\n"
u8"Z‚ÜźA LO B ‚óä T‚ÜźZ RO B ‚óä B‚ÜźZ ‚óä 0 ‚Üí (,T)‚ČĘ,1\n")

/// reduce: Z‚ÜźLO/[X] B
//
mac_def(Z__LO_REDUCE_X4_B,
u8" Z‚Üź(LO Z__LO_REDUCE_X4_B) [X4] B;B3;T;H;M;M_max;L;N;I;I_max\n"
u8" (X4 H M_max L)‚ÜźX4 ‚óä B3‚Üź(H M_max L)‚ćīB ‚óä I_max‚Üź‚éēIO+‚ćīI‚Üź,‚ć≥‚ćīZ‚Üź(H, L)‚ćī0 ‚óä N‚Üź‚éēIO\n"
u8" (H L)‚Üź‚äÉI[N] ‚óä M‚ÜźM_max-2 ‚óä T‚ÜźB3[H;‚éēIO+M_max-1;L]\n"
u8" T‚Üź ‚äā(‚äÉB3[H;‚éēIO+M;L]) LO ‚äÉT ‚óä  0 ‚Üí 0‚Č§M‚ÜźM-1\n"
u8" Z[H;L]‚ÜźT                   ‚óä ¬Į2 ‚Üí I_max>N‚ÜźN+1\n"
u8" Z‚Üź((X4‚Č†‚ć≥‚ćī‚ćīB)/‚ćīB)‚ćīZ\n")

/// reduce N-wise: Z‚ÜźA LO/[X] B with positive A
//
mac_def(   Z__pA_LO_REDUCE_X4_B,
u8" Z‚ÜźA1 (LO Z__pA_LO_REDUCE_X4_B) [X4] B;rho_B3;B3;rho_Z;rho_Z3;T;H;M;L;a;N;I;I_max\n"
u8" (X4 rho_Z rho_Z3 rho_B3)‚ÜźX4 ‚óä B3‚Üźrho_B3‚ćīB ‚óä I_max‚Üź‚éēIO+‚ćīI‚Üź,‚ć≥‚ćīZ‚Üź(rho_Z3)‚ćī0 ‚óä N‚Üź‚éēIO\n"
u8" (H a L)‚Üź‚äÉI[N] ‚óä M‚ÜźA1+1 ‚óä T‚ÜźB3[H;a-A1;L]\n"
u8" T‚Üź ‚äā(‚äÉB3[H;a-M;L]) LO ‚äÉT ‚óä  0 ‚Üí 0‚Č•M‚ÜźM+1\n"
u8" Z[H;a;L]‚ÜźT               ‚óä ¬Į2 ‚ÜíI_max>N‚ÜźN+1\n"
u8" Z‚Üźrho_Z‚ćīZ\n")

/// reduce N-wise: Z‚ÜźA LO/[X] B with negative A
//
mac_def(   Z__nA_LO_REDUCE_X4_B,
u8" Z‚ÜźA1 (LO Z__nA_LO_REDUCE_X4_B) [X4] B;rho_B3;B3;rho_Z;rho_Z3;T;H;M;L;a;N;I;I_max\n"
u8" (X4 rho_Z rho_Z3 rho_B3)‚ÜźX4 ‚óä B3‚Üźrho_B3‚ćīB ‚óä I_max‚Üź‚éēIO+‚ćīI‚Üź,‚ć≥‚ćīZ‚Üź(rho_Z3)‚ćī0 ‚óä N‚Üź‚éēIO\n"
u8" (H a L)‚Üź‚äÉI[N] ‚óä M‚Üź¬Į1 ‚óä T‚ÜźB3[H;a;L]\n"
u8" T‚Üź ‚äā((‚äÉB3[H;a-M;L]) LO ‚äÉT) ‚óä  0 ‚Üí A1‚Č§M‚ÜźM-1\n"
u8" Z[H;a;L]‚ÜźT                 ‚óä ¬Į2 ‚ÜíI_max>N‚ÜźN+1\n"
u8" Z‚Üźrho_Z‚ćīZ\n")

/// scan: Z‚ÜźLO/[X] B
//
mac_def(  Z__LO_SCAN_X4_B,
  u8" Z‚Üź(LO Z__LO_SCAN_X4_B) [X4] B;B3;T;H;M;M_max;L;a;N;I;I_max\n"
u8" (X4 H M_max L)‚ÜźX4 ‚óä I_max‚Üź‚éēIO+‚ćīI‚Üź,‚ć≥‚ćīZ‚ÜźB3‚Üź(H M_max L)‚ćīB ‚óä N‚Üź‚éēIO - 1\n"
u8" (H a L)‚Üź‚äÉI[N‚ÜźN+1]          ‚óä  0 ‚Üí a=‚éēIO ‚óä M‚Üź1 ‚óä T‚ÜźB3[H;a;L]\n"
u8" T‚Üź ‚äā((‚äÉB3[H;a-M;L]) LO ‚äÉT) ‚óä  0 ‚Üí a>M‚ÜźM+1\n"
u8" Z[H;a;L]‚ÜźT                 ‚óä ¬Į2 ‚Üí I_max>N+1\n"
u8" Z‚Üź(‚ćīB)‚ćīZ\n")

/// rank: Z‚Üź  (LO‚ć§j) B and Z‚Üź  (LO‚ć§[X]j) 
//
mac_def(Z__LO_RANK_X5_B,
 u8"Z‚Üź(LO Z__LO_RANK_X5_B) [X5] B;LB;rho_B;N_max;N;LZ;rho_Z\n"
u8" (X5 LB rho_B LZ rho_Z)‚ÜźX5 ‚óä B‚Üź(LZ,LB)‚ćīB ‚óä N_max‚ÜźLZ+N‚Üź‚éēIO ‚óä Z‚ÜźLZ‚ćī0\n"
u8" Z[N]‚Üź‚äāLO rho_B‚ćīB[N;] ‚óä 0 ‚Üí N_max>N‚ÜźN+1\n"
u8"‚Üí(X5‚ČĘ¬Į1)‚ćīWITH_AXES ‚óä Z‚Üź30 ‚éēCR rho_Z‚ćīZ ‚óä ‚Üí0\n"
u8"WITH_AXES:           Z‚Üź‚äÉ[X5]rho_Z‚ćīZ\n")

/// rank: Z‚ÜźA (LO‚ć§j) B and Z‚Üź(A LO‚ć§[X]j) 
//
mac_def(  Z__A_LO_RANK_X7_B,
 u8"Z‚ÜźA (LO Z__A_LO_RANK_X7_B)[X7] B;LA;rho_A;LB;rho_B;N_max;N;LZ;rho_Z\n"
u8" (X7 LA rho_A LB rho_B LZ rho_Z)‚ÜźX7 ‚óä A‚Üź(LZ,LA)‚ćīA ‚óä B‚Üź(LZ,LB)‚ćīB\n"
u8" N_max‚ÜźLZ+N‚Üź‚éēIO ‚óä Z‚ÜźLZ‚ćī0\n"
u8" Z[N]‚Üź‚äā(rho_A‚ćīA[N;]) LO rho_B‚ćīB[N;] ‚óä 0 ‚Üí N_max>N‚ÜźN+1\n"
u8" ‚Üí(X7‚ČĘ¬Į1)‚ćīWITH_AXES ‚óä Z‚Üź30 ‚éēCR rho_Z‚ćīZ ‚óä ‚Üí0\n"
u8"WITH_AXES:           Z‚Üź‚äÉ[X7]rho_Z‚ćīZ\n")

/// ‚éēINP helper
//
mac_def(Z__Quad_INP_B,
    u8" B‚ÜźZ__Quad_INP_B B;C;C_max;N;N_max;ROW\n"
u8" N‚Üź‚éēIO ‚óä N_max‚ÜźN+‚ÜĎ(‚ćīB),1\n"
u8" ROW‚Üź‚äÉB[N] ‚óä C‚Üź¬Į1+‚éēIO ‚óä C_max‚ÜźC+‚éēIO+‚ćīROW ‚óä ‚ÜíCX\n"
u8" ROW[C]‚Üź‚äā‚ćē‚ćé‚äÉROW[C]\n"
u8"CX: ¬Į1 ‚Üí C_max>C‚ÜźC+2 ‚óä B[N]‚Üź31 ‚éēCR ‚äāROW ‚óä ¬Į2 ‚Üí N_max>N‚ÜźN+1\n")

/// ‚éēEA (Execute Alternate) helper
//
mac_def(Z__A_Quad_EA_B,
  u8" Z‚ÜźA Z__A_Quad_EA_B B;RC;ET;RES\n"
u8"     (RC ET RES)‚Üź‚éēEC B ‚óä ‚Üí(RC=0 1 2 3 4 5)/ERR VAL COM 0 BRA ESC\n"
u8"ERR: ‚éēES 100 $FFFF,  (‚äā,A),  ET     ‚ćĚ error\n"
u8"VAL: Z‚ÜźRES      ‚óä ‚Üí0                ‚ćĚ non-committed value\n"
u8"COM: ‚éēES 100 $FFFE   RES            ‚ćĚ committed value\n"
u8"BRA: ‚éēES 100 $FFFD   RES            ‚ćĚ ‚ÜíN\n"
u8"ESC: ‚éēES 100 $FFFC                  ‚ćĚ ‚Üí\n")

/// ‚éēEB (Execute Both) helper
//
mac_def(Z__A_Quad_EB_B,
  u8" Z‚ÜźA Z__A_Quad_EB_B B;RC;ET;RES\n"
u8"     (RC ET RES)‚Üź‚éēEC B ‚óä ‚ćéA\n"
u8"     ‚Üí(RC=0 1 2 3 4 5)/ERR VAL COM 0 BRA ESC\n"
u8"ERR: ‚éēES ET     ‚óä ‚Üí0                ‚ćĚ error\n"
u8"VAL: Z‚ÜźRES      ‚óä ‚Üí0                ‚ćĚ non-committed value\n"
u8"COM: ‚éēES 100 $FFFE   RES            ‚ćĚ committed value\n"
u8"BRA: ‚éēES 100 $FFFD   RES            ‚ćĚ ‚ÜíN\n"
u8"ESC: ‚éēES 100 $FFFC                  ‚ćĚ ‚Üí\n")

/// inner product with A and B of rank ‚Č§ 1
//
mac_def(  Z__vA_LO_INNER_RO_vB,
 u8"Z‚ÜźA (LO Z__A_LO_INNER_RO_B RO) B\n"
 u8"Z‚ÜźLO/(,A) RO ,B\n")

/// monadic EACH with ‚ćé
//
mac_def(Z__EXEC_EACH_B,
 u8"Z‚Üź Z__EXEC_EACH_B B;T;rho_Z;RC;ET;ZZ;J;N;N3;V3;N_max\n"
 u8" N‚Üź‚éēIO ‚óä rho_Z‚Üź‚ćīB ‚óä N_max‚ÜźN+‚ćīB‚Üź,B ‚óä T‚Üź(‚ćīB)‚ćī0 ‚óä V3‚ÜźN3‚Üź‚éēIO\n"
 u8" J‚ÜźRC0, RC12, RC12, RC3, RC4, RC5\n"
 u8"LOOP:  (RC ET ZZ)‚Üź‚éēEC ‚äÉB[N] ‚óä ‚ÜíJ[‚éēIO+RC]\n"
 u8" RC0:  ((‚äÉZZ)[‚éēIO;], ' in macro ‚ćé¬®') ‚éēES ‚äÉET\n"
 u8" RC12: T[N]‚Üź‚äāZZ ‚óä N3‚ÜźN3+1 ‚óä ‚Üí(N_max>N‚ÜźN+1)‚ćīLOOP ‚óä ‚ÜíDONE\n"
 u8" RC3:             V3‚ÜźV3+1 ‚óä ‚Üí(N_max>N‚ÜźN+1)‚ćīLOOP ‚óä ‚ÜíDONE\n"
 u8" RC4: 'SYNTAX ERROR: ‚ÜíN in macro ‚ćé¬®' ‚éēES 2 2\n"
 u8" RC5: 'SYNTAX ERROR: ‚Üí in macro ‚ćé¬®'  ‚éēES 2 2\n"
 u8" DONE: ‚Üí(V3=N_max)‚ćī0                      ‚ćĚ NO RESULT\n"
 u8" ‚Üí(N3‚Č†N_max)/MISMATCH ‚óä Z‚Üźrho_Z‚ćīT ‚óä ‚Üí0\n  ‚ćĚ RESULT\n"
 u8"MISMATCH: 'VALUE ERROR in macro ‚ćé¬®' ‚éēES 3 1\n")

#undef mac_def

/// \endcond

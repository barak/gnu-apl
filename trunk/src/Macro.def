/// \cond NOPE

/// monadic EACH without result
//
mac_def(LO_EACH_B,
 "(LO LO_EACH_B) B;N;N_max\n"
 "N‚Üê‚éïIO ‚óä N_max‚ÜêN+‚ç¥B‚Üê,B\n"
 "LO N‚äÉB ‚óä 0 ‚Üí N_max>N‚ÜêN+1\n")

/// dyadic EACH without result, scalar A, scalar B
//
mac_def(sA_LO_EACH_sB,
 "A (LO sa_LO_EACH_sB) B\n"
 "A LO B\n")

/// dyadic EACH without result, scalar A, vector B
//
mac_def(sA_LO_EACH_vB,
 "A (LO sa_LO_EACH_vB) B;N;N_max\n"
 "N‚Üê‚éïIO ‚óä N_max‚ÜêN+‚ç¥B‚Üê,B\n"
 "(‚äÉA) LO N‚äÉB ‚óä 0 ‚Üí N_max>N‚ÜêN+1\n")

/// dyadic EACH without result, vector A, scalar B
//
mac_def(vA_LO_EACH_sB,
 "A (LO vA_LO_EACH_sB) B;N;N_max\n"
 "N‚Üê‚éïIO ‚óä N_max‚ÜêN+‚ç¥A‚Üê,A\n"
 "(N‚äÉA) LO ‚äÉB ‚óä 0 ‚Üí N_max>N‚ÜêN+1\n")

/// dyadic EACH without result, vector A, vector B
//
mac_def(vA_LO_EACH_vB,
 "A (LO vA_LO_EACH_vB) B;N;N_max\n"
 "N‚Üê‚éïIO ‚óä A‚Üê,A ‚óä N_max‚ÜêN+‚ç¥B‚Üê,B\n"
 "(N‚äÉA) LO N‚äÉB ‚óä 0 ‚Üí N_max>N‚ÜêN+1\n")

/// monadic EACH with result
//
mac_def(Z__LO_EACH_B, 
 "Z‚Üê(LO Z__LO_EACH_B) B;rho_Z;N;N_max\n"
 "rho_Z‚Üê‚ç¥B ‚óä N‚Üê‚éïIO ‚óä N_max‚ÜêN+‚ç¥B‚Üê,B ‚óä Z‚ÜêN_max‚ç¥0\n"
 "(N‚äÉZ)‚ÜêLO N‚äÉB ‚óä 0 ‚Üí N_max>N‚ÜêN+1\n"
 "Z‚Üêrho_Z‚ç¥Z\n")

/// dyadic EACH with result, scalar A, scalar B
//
mac_def(Z__sA_LO_EACH_sB,
 "Z‚ÜêA (LO Z__sA_LO_EACH_sB) B\n"
 "Z‚Üê‚äÇA LO B\n")

/// dyadic EACH with result, scalar A, vector B
//
mac_def(  Z__sA_LO_EACH_vB, 
 "Z‚ÜêA (LO Z__sA_LO_EACH_vB) B;rho_Z;N;N_max\n"
 "rho_Z‚Üê‚ç¥B ‚óä N‚Üê‚éïIO ‚óä N_max‚ÜêN+‚ç¥B‚Üê,B ‚óä Z‚ÜêN_max‚ç¥0\n"
 "(N‚äÉZ)‚Üê‚äÇ(‚äÉA) LO N‚äÉB ‚óä 0 ‚Üí N_max>N‚ÜêN+1\n"
 "Z‚Üêrho_Z‚ç¥Z\n")

/// dyadic EACH with result, vector A, scalar B
//
mac_def(  Z__vA_LO_EACH_sB, 
 "Z‚ÜêA (LO Z__vA_LO_EACH_sB) B;rho_Z;N;N_max\n"
 "rho_Z‚Üê‚ç¥A ‚óä N‚Üê‚éïIO ‚óä N_max‚ÜêN+‚ç¥A‚Üê,A ‚óä Z‚ÜêN_max‚ç¥0\n"
 "(N‚äÉZ)‚Üê‚äÇ(N‚äÉA) LO ‚äÉB ‚óä 0 ‚Üí N_max>N‚ÜêN+1\n"
 "Z‚Üêrho_Z‚ç¥Z\n")

/// dyadic EACH with result, vector A, vector B
//
mac_def(  Z__vA_LO_EACH_vB,
 "Z‚ÜêA (LO Z__vA_LO_EACH_vB) B;rho_Z;N;N_max\n"
 "‚Üí((‚ç¥A)‚â°‚ç¥B)‚ç¥SHAPES_MATCH ‚óä ‚éïES 5,2+(‚ç¥‚ç¥A)=‚ç¥‚ç¥B\n"
 "SHAPES_MATCH: rho_Z‚Üê‚ç¥B ‚óä N‚Üê‚éïIO ‚óä A‚Üê,A ‚óä N_max‚ÜêN+‚ç¥B‚Üê,B ‚óä Z‚ÜêN_max‚ç¥0\n"
 "(N‚äÉZ)‚Üê(N‚äÉA) LO N‚äÉB ‚óä 0 ‚Üí N_max>N‚ÜêN+1\n"
 "Z‚Üêrho_Z‚ç¥Z\n")

/// outer product
//
mac_def(  Z__A_LO_OUTER_B,
 "Z‚ÜêA (LO Z__A_LO_OUTER_B) B;rho_Z;N;N_max;I;IA;IB\n"
 "rho_Z‚Üê(‚ç¥A),‚ç¥B ‚óä N‚Üê‚éïIO ‚óä A‚Üê,A ‚óä B‚Üê,B ‚óä I‚Üê,‚ç≥(‚ç¥A),‚ç¥B ‚óä N_max‚ÜêN+‚ç¥I ‚óä Z‚ÜêN_max‚ç¥0\n"
 "(IA IB)‚Üê‚äÉI[N] ‚óä Z[N]‚Üê‚äÇ(‚äÉA[IA]) LO ‚äÉB[IB] ‚óä 0 ‚Üí N_max>N‚ÜêN+1\n"
 "Z‚Üêrho_Z‚ç¥Z\n")

/// inner product. caller has checked that the shapes of A and B fit
//
mac_def(  Z__A_LO_INNER_RO_B,
 "Z‚ÜêA (LO INNER RO) B;‚éïIO\n"
 "    ‚éïIO‚Üê1 ‚óä ‚Üí (‚ç¥‚ç¥A) ‚Üì sA ‚óä ‚Üí (‚ç¥‚ç¥B) ‚Üì vA_sB\n"
 "vA_vB: Z‚ÜêLO/¬® (‚äÇ[œÅœÅA]A) ‚àò.RO ‚äÇ[1]B ‚óä ‚Üí0\n"
 "vA_sB: Z‚ÜêLO/¬® (‚äÇ[œÅœÅA]A) ‚àò.RO ‚äÇB    ‚óä ‚Üí0\n"
 "sA: ‚Üí (‚ç¥‚ç¥B) ‚Üì sA_sB\n"
 "sA_vB: Z‚ÜêLO/¬® (‚äÇA)      ‚àò.RO ‚äÇ[1]B ‚óä ‚Üí0\n"
 "sA_sB: Z‚ÜêLO/¬® (‚äÇA)      ‚àò.RO ‚äÇB    ‚óä ‚Üí0\n")

/// monadic power with repeat count and no result
//
mac_def(  LO_POWER_N_B,
  " A (LO LO_POWER_N_B N) Z\n"
"LO Z ‚óä 0 ‚Üí 0<N‚ÜêN-1\n")

/// dyadic power with repeat count and no result
//
mac_def(  A_LO_POWER_N_B,
  " A (LO A_LO_POWER_N_B N) Z\n"
"A LO Z ‚óä 0 ‚Üí 0<N‚ÜêN-1\n")

/// monadic power with repeat count and result
//
mac_def(  Z__LO_POWER_N_B,
" Z‚ÜêA (LO Z__LO_POWER_N_B N) Z\n"
" Z‚ÜêLO Z ‚óä 0 ‚Üí 0<N‚ÜêN-1\n")

/// dyadic power with repeat count and result
//
mac_def(  Z__A_LO_POWER_N_B,
" Z‚ÜêA (LO Z__A_LO_POWER_N_B N) Z\n"
"Z‚ÜêA LO Z ‚óä 0 ‚Üí 0<N‚ÜêN-1\n")

/// monadic power with condition function RO and no result
//
mac_def(  Z__LO_POWER_RO_B,
  " Z‚Üê(LO Z__LO_POWER_RO_B RO) B;T\n"
"Z‚ÜêLO B ‚óä T‚ÜêZ RO B ‚óä B‚ÜêZ ‚óä 0 ‚Üí(,T)‚â¢,1\n")

/// monadic power with condition function RO and result
//
mac_def(  Z__A_LO_POWER_RO_B,
" Z‚ÜêA (LO Z__A_LO_POWER_RO_B RO) B;T\n"
"Z‚ÜêA LO B ‚óä T‚ÜêZ RO B ‚óä B‚ÜêZ ‚óä 0 ‚Üí (,T)‚â¢,1\n")

/// reduce: Z‚ÜêLO/[X] B
//
mac_def(Z__LO_REDUCE_X4_B,
" Z‚Üê(LO Z__LO_REDUCE_X4_B) [X4] B;B3;T;H;M;M_max;L;N;I;I_max\n"
" (X4 H M_max L)‚ÜêX4 ‚óä B3‚Üê(H M_max L)‚ç¥B ‚óä I_max‚Üê‚éïIO+‚ç¥I‚Üê,‚ç≥‚ç¥Z‚Üê(H, L)‚ç¥0 ‚óä N‚Üê‚éïIO\n"
" (H L)‚Üê‚äÉI[N] ‚óä M‚ÜêM_max-2 ‚óä T‚ÜêB3[H;‚éïIO+M_max-1;L]\n"
" T‚Üê ‚äÇ(‚äÉB3[H;‚éïIO+M;L]) LO ‚äÉT ‚óä  0 ‚Üí 0‚â§M‚ÜêM-1\n"
" Z[H;L]‚ÜêT                   ‚óä ¬Ø2 ‚Üí I_max>N‚ÜêN+1\n"
" Z‚Üê((X4‚âÝ‚ç≥‚ç¥‚ç¥B)/‚ç¥B)‚ç¥Z\n")

/// reduce N-wise: Z‚ÜêA LO/[X] B with positive A
//
mac_def(   Z__pA_LO_REDUCE_X4_B,
" Z‚ÜêA1 (LO Z__pA_LO_REDUCE_X4_B) [X4] B;rho_B3;B3;rho_Z;rho_Z3;T;H;M;L;a;N;I;I_max\n"
" (X4 rho_Z rho_Z3 rho_B3)‚ÜêX4 ‚óä B3‚Üêrho_B3‚ç¥B ‚óä I_max‚Üê‚éïIO+‚ç¥I‚Üê,‚ç≥‚ç¥Z‚Üê(rho_Z3)‚ç¥0 ‚óä N‚Üê‚éïIO\n"
" (H a L)‚Üê‚äÉI[N] ‚óä M‚ÜêA1+1 ‚óä T‚ÜêB3[H;a-A1;L]\n"
" T‚Üê ‚äÇ(‚äÉB3[H;a-M;L]) LO ‚äÉT ‚óä  0 ‚Üí 0‚â•M‚ÜêM+1\n"
" Z[H;a;L]‚ÜêT               ‚óä ¬Ø2 ‚ÜíI_max>N‚ÜêN+1\n"
" Z‚Üêrho_Z‚ç¥Z\n")

/// reduce N-wise: Z‚ÜêA LO/[X] B with negative A
//
mac_def(   Z__nA_LO_REDUCE_X4_B,
" Z‚ÜêA1 (LO Z__nA_LO_REDUCE_X4_B) [X4] B;rho_B3;B3;rho_Z;rho_Z3;T;H;M;L;a;N;I;I_max\n"
" (X4 rho_Z rho_Z3 rho_B3)‚ÜêX4 ‚óä B3‚Üêrho_B3‚ç¥B ‚óä I_max‚Üê‚éïIO+‚ç¥I‚Üê,‚ç≥‚ç¥Z‚Üê(rho_Z3)‚ç¥0 ‚óä N‚Üê‚éïIO\n"
" (H a L)‚Üê‚äÉI[N] ‚óä M‚Üê¬Ø1 ‚óä T‚ÜêB3[H;a;L]\n"
" T‚Üê ‚äÇ((‚äÉB3[H;a-M;L]) LO ‚äÉT) ‚óä  0 ‚Üí A1‚â§M‚ÜêM-1\n"
" Z[H;a;L]‚ÜêT                 ‚óä ¬Ø2 ‚ÜíI_max>N‚ÜêN+1\n"
" Z‚Üêrho_Z‚ç¥Z\n")

/// scan: Z‚ÜêLO/[X] B
//
mac_def(  Z__LO_SCAN_X4_B,
  " Z‚Üê(LO Z__LO_SCAN_X4_B) [X4] B;B3;T;H;M;M_max;L;a;N;I;I_max\n"
" (X4 H M_max L)‚ÜêX4 ‚óä I_max‚Üê‚éïIO+‚ç¥I‚Üê,‚ç≥‚ç¥Z‚ÜêB3‚Üê(H M_max L)‚ç¥B ‚óä N‚Üê‚éïIO - 1\n"
" (H a L)‚Üê‚äÉI[N‚ÜêN+1]          ‚óä  0 ‚Üí a=‚éïIO ‚óä M‚Üê1 ‚óä T‚ÜêB3[H;a;L]\n"
" T‚Üê ‚äÇ((‚äÉB3[H;a-M;L]) LO ‚äÉT) ‚óä  0 ‚Üí a>M‚ÜêM+1\n"
" Z[H;a;L]‚ÜêT                 ‚óä ¬Ø2 ‚Üí I_max>N+1\n"
" Z‚Üê(‚ç¥B)‚ç¥Z\n")

/// rank: Z‚Üê  (LO‚ç§j) B and Z‚Üê  (LO‚ç§[X]j) 
//
mac_def(Z__LO_RANK_X5_B,
 "Z‚Üê(LO Z__LO_RANK_X5_B) [X5] B;LB;rho_B;N_max;N;LZ;rho_Z\n"
" (X5 LB rho_B LZ rho_Z)‚ÜêX5 ‚óä B‚Üê(LZ,LB)‚ç¥B ‚óä N_max‚ÜêLZ+N‚Üê‚éïIO ‚óä Z‚ÜêLZ‚ç¥0\n"
" Z[N]‚Üê‚äÇLO rho_B‚ç¥B[N;] ‚óä 0 ‚Üí N_max>N‚ÜêN+1\n"
"‚Üí(X5‚â¢¬Ø1)‚ç¥WITH_AXES ‚óä Z‚Üê30 ‚éïCR rho_Z‚ç¥Z ‚óä ‚Üí0\n"
"WITH_AXES:           Z‚Üê‚äÉ[X5]rho_Z‚ç¥Z\n")

/// rank: Z‚ÜêA (LO‚ç§j) B and Z‚Üê(A LO‚ç§[X]j) 
//
mac_def(  Z__A_LO_RANK_X7_B,
 "Z‚ÜêA (LO Z__A_LO_RANK_X7_B)[X7] B;LA;rho_A;LB;rho_B;N_max;N;LZ;rho_Z\n"
" (X7 LA rho_A LB rho_B LZ rho_Z)‚ÜêX7 ‚óä A‚Üê(LZ,LA)‚ç¥A ‚óä B‚Üê(LZ,LB)‚ç¥B\n"
" N_max‚ÜêLZ+N‚Üê‚éïIO ‚óä Z‚ÜêLZ‚ç¥0\n"
" Z[N]‚Üê‚äÇ(rho_A‚ç¥A[N;]) LO rho_B‚ç¥B[N;] ‚óä 0 ‚Üí N_max>N‚ÜêN+1\n"
" ‚Üí(X7‚â¢¬Ø1)‚ç¥WITH_AXES ‚óä Z‚Üê30 ‚éïCR rho_Z‚ç¥Z ‚óä ‚Üí0\n"
"WITH_AXES:           Z‚Üê‚äÉ[X7]rho_Z‚ç¥Z\n")

/// ‚éïINP helper
//
mac_def(Z__Quad_INP_B,
    " B‚ÜêZ__Quad_INP_B B;C;C_max;N;N_max;ROW\n"
" N‚Üê‚éïIO ‚óä N_max‚ÜêN+‚Üë(‚ç¥B),1\n"
" ROW‚Üê‚äÉB[N] ‚óä C‚Üê¬Ø1+‚éïIO ‚óä C_max‚ÜêC+‚éïIO+‚ç¥ROW ‚óä ‚ÜíCX\n"
" ROW[C]‚Üê‚äÇ‚çï‚çé‚äÉROW[C]\n"
"CX: ¬Ø1 ‚Üí C_max>C‚ÜêC+2 ‚óä B[N]‚Üê31 ‚éïCR ‚äÇROW ‚óä ¬Ø2 ‚Üí N_max>N‚ÜêN+1\n")

/// ‚éïEA (Execute Alternate) helper
//
mac_def(Z__A_Quad_EA_B,
  " Z‚ÜêA Z__A_Quad_EA_B B;RC;ET;RES\n"
"     (RC ET RES)‚Üê‚éïEC B ‚óä ‚Üí(RC=0 1 2 3 4 5)/ERR VAL COM 0 BRA ESC\n"
"ERR: ‚éïES 100 $FFFF,  (‚äÇ,A),  ET     ‚çù error\n"
"VAL: Z‚ÜêRES      ‚óä ‚Üí0                ‚çù non-committed value\n"
"COM: ‚éïES 100 $FFFE   RES            ‚çù committed value\n"
"BRA: ‚éïES 100 $FFFD   RES            ‚çù ‚ÜíN\n"
"ESC: ‚éïES 100 $FFFC                  ‚çù ‚Üí\n")

/// ‚éïEB (Execute Both) helper
//
mac_def(Z__A_Quad_EB_B,
  " Z‚ÜêA Z__A_Quad_EB_B B;RC;ET;RES\n"
"     (RC ET RES)‚Üê‚éïEC B ‚óä ‚çéA\n"
"     ‚Üí(RC=0 1 2 3 4 5)/ERR VAL COM 0 BRA ESC\n"
"ERR: ‚éïES ET     ‚óä ‚Üí0                ‚çù error\n"
"VAL: Z‚ÜêRES      ‚óä ‚Üí0                ‚çù non-committed value\n"
"COM: ‚éïES 100 $FFFE   RES            ‚çù committed value\n"
"BRA: ‚éïES 100 $FFFD   RES            ‚çù ‚ÜíN\n"
"ESC: ‚éïES 100 $FFFC                  ‚çù ‚Üí\n")

/// inner product with A and B of rank ‚â§ 1
//
mac_def(  Z__vA_LO_INNER_RO_vB,
 "Z‚ÜêA (LO Z__A_LO_INNER_RO_B RO) B\n"
 "Z‚ÜêLO/(,A) RO ,B\n")

/// monadic EACH with ‚çé
//
mac_def(Z__EXEC_EACH_B,
 "Z‚Üê Z__EXEC_EACH_B B;T;rho_Z;RC;ET;ZZ;J;N;N3;V3;N_max\n"
 " N‚Üê‚éïIO ‚óä rho_Z‚Üê‚ç¥B ‚óä N_max‚ÜêN+‚ç¥B‚Üê,B ‚óä T‚Üê(‚ç¥B)‚ç¥0 ‚óä V3‚ÜêN3‚Üê‚éïIO\n"
 " J‚ÜêRC0, RC12, RC12, RC3, RC4, RC5\n"
 "LOOP:  (RC ET ZZ)‚Üê‚éïEC ‚äÉB[N] ‚óä ‚ÜíJ[‚éïIO+RC]\n"
 " RC0:  ((‚äÉZZ)[‚éïIO;], ' in macro ‚çé¬®') ‚éïES ‚äÉET\n"
 " RC12: T[N]‚Üê‚äÇZZ ‚óä N3‚ÜêN3+1 ‚óä ‚Üí(N_max>N‚ÜêN+1)‚ç¥LOOP ‚óä ‚ÜíDONE\n"
 " RC3:             V3‚ÜêV3+1 ‚óä ‚Üí(N_max>N‚ÜêN+1)‚ç¥LOOP ‚óä ‚ÜíDONE\n"
 " RC4: 'SYNTAX ERROR: ‚ÜíN in macro ‚çé¬®' ‚éïES 2 2\n"
 " RC5: 'SYNTAX ERROR: ‚Üí in macro ‚çé¬®'  ‚éïES 2 2\n"
 " DONE: ‚Üí(V3=N_max)‚ç¥0                      ‚çù NO RESULT\n"
 " ‚Üí(N3‚âÝN_max)/MISMATCH ‚óä Z‚Üêrho_Z‚ç¥T ‚óä ‚Üí0\n  ‚çù RESULT\n"
 "MISMATCH: 'VALUE ERROR in macro ‚çé¬®' ‚éïES 3 1\n")

#undef mac_def

/// \endcond

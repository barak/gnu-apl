      вНЭ
      SOL_SOCKETвЖР1
      SO_REUSEADDRвЖР2
      (SOL_SOCKET, SO_REUSEADDR, 1) FILE_IO[47] Handle
0

      вНЭ bind(AF_INET, LOCALHOST, Port)
      вНЭ
      Server FILE_IO[33] Handle
0

      вНЭ listen(10)
      вНЭ
      10 FILE_IO[34] Handle
0

      вНЭ socket(AF_INET, SOCK_STREAM, PROTO)
      вНЭ
      4 вЙ§ Handle1вЖРFILE_IO[32] AF_INET, SOCK_STREAM, PROTO
1

      вНЭ connect() Handle1 to Handle
      вНЭ

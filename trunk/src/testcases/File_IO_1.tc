      вНЭ socket communication: send 'Hello' from one socket to another
      вНЭ
      AF_INET     вЖР 2
      SOCK_STREAM вЖР 1
      PROTO       вЖР 0
      LOCALHOSTвЖР256вК•127 0 0 1
      Port вЖР 22222
      ServerвЖРAF_INET, LOCALHOST, Port

      вНЭ socket(AF_INET, SOCK_STREAM, PROTO)
      вНЭ
      3 вЙ§ HandleвЖРFILE_IO[32] AF_INET, SOCK_STREAM, PROTO
1


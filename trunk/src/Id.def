st( IF_ELSE            , u8"←→"         ,          )
st( IF_END             , u8"←←"         ,          )
st( IF_THEN            , u8"→→"         ,          )
                                    
sf( JOT           , u8"∘"               , = 0x4A01 )   // C...
qf( JSON               , u8"⎕JSON"      ,          )
                                    
qv( L                  , u8"⎕L"         , = 0x4C01 )   // L...
st( L_BRACK            , "["          ,          )
st( L_CURLY            , "{"          ,          )
st( L_PARENT           , "("          ,          )
qv( LC                 , u8"⎕LC"        ,          )
sf( F2_LEFT            , u8"⊣"          ,          )
sf( F2_LEQU            , u8"≤"          ,          )
sf( F2_LESS            , "<"          ,          )
sf( F12_LOGA           , u8"⍟"          ,          )
pp( LVAL               , ---          ,          )
qv( LX                 , u8"⎕LX"        ,          )
st( LAMBDA             , u8"λ"          ,          )
                                    
sf( F2_MEQU            , u8"≥"          , = 0x4D01 )   // M...
sf( F12_MINUS          , "-"          ,          )
st( MACRO              , "MACRO"      ,          )
qf( MAP                , u8"⎕MAP"       ,          )
qf( MX                 , u8"⎕MX"        ,          )
pp( MARKER             , "@n@"        ,          )   // string marker
                                    
qf( NA                 , u8"⎕NA"        , = 0x4E01 )
sf( F2_NAND            , u8"⍲"          ,          )
qf( NC                 , u8"⎕NC"        ,          )
qf( NL                 , u8"⎕NL"        ,          )
  /**  ⎕NLT removed                          **/
pp( NO_VALUE           , ---          , = 0x4E06 )   // N...
sf( F2_NOR             , u8"⍱"          ,          )
sf( F12_NEQUIV         , u8"≢"          ,          )
sf( F2_NAND_B          , u8"⊤⍲"         ,          )
sf( F2_NOR_B            , u8"⊤⍱"        ,          )
                                    
pp( OFF                , ---          , = 0x4F01 )   // O...
sf( F2_OR              , u8"∨"          ,          )
st( OMEGA              , u8"⍵"          ,          )
st( OMEGA_U            , u8"⍹"          ,          )
sf( OPER2_OUTER        , u8"∘."         ,          )
sf( F2_OR_B            , u8"⊤∨"         ,          )
                                    
sf( F12_PARTITION      , u8"⊂"          , = 0x5001 )   // P...
sf( F12_PICK           , u8"⊃"          ,          )
sf( F12_PLUS           , "+"          ,          )
sf( F12_POWER          , u8"⋆"          ,          )
qv( PP                 , u8"⎕PP"        ,          )
qv( PR                 , u8"⎕PR"        ,          )
qv( PS                 , u8"⎕PS"        ,          )
  /** ⎕PT            removed                 **/
  /**  OPER2_PRODUCT removed                 **/
qv( PW                 , u8"⎕PW"        , = 0x5009 )   // P...
sf( OPER2_POWER        , u8"⍣"          ,          )
qf( PLOT               , u8"⎕PLOT"      ,          )
qf( PNG                , u8"⎕PNG"        ,          )
                                    
st( Quad_Quad          , u8"⎕"          , = 0x5101 )   // Q...
st( QUOTE1             , "'"          ,          )
st( QUOTE2             , "\""         ,          )
st( QUOTE_Quad         , u8"⍞"          ,          )
st( Quad_PREFIX        , ""           ,          )
                                    
qv( R                  , u8"⎕R"         , = 0x5201 )   // R...
st( R_ARROW            , u8"→"          ,          )
st( R_BRACK            , "]"          ,          )
st( R_CURLY            , "}"          ,          )
st( R_PARENT           , ")"          ,          )
sf( OPER2_RANK         , u8"⍤"          ,          )
pp( REAL               , ---          ,          )
sf( OPER1_REDUCE       , "/"          ,          )
sf( OPER1_REDUCE1      , u8"⌿"          ,          )
pp( RETURN_EXEC        , ---          ,          )   // ⍎X
pp( RETURN_STATS       , ---          ,          )   // A ◊ B ◊ C
pp( RETURN_SYMBOL      , ---          ,          )   // Z←A FUN B
pp( RETURN_VOID        , ---          ,          )   // A FUN B
sf( F12_RHO            , u8"⍴"          ,          )
sf( F2_RIGHT           , u8"⊢"          ,          )
qv( RL                 , u8"⎕RL"        ,          )
sf( F12_RND_DN         , u8"⌊"          ,          )
sf( F12_RND_UP         , u8"⌈"          ,          )
sf( F12_ROLL           , "?"          ,          )
sf( F12_ROTATE         , u8"⌽"          ,          )
sf( F12_ROTATE1        , u8"⊖"          ,          )
qf( RVAL               , u8"⎕RVAL"      ,          )
                                    
sf( OPER1_SCAN         , "\\"         , = 0x5301 )   // S...
sf( OPER1_SCAN1        , u8"⍀"          ,          )
st( SEMICOL            , ";"          ,          )
qf( SI                 , u8"⎕SI"        ,          )
pp( SI_PUSHED          , ---          ,          )
pp( SI_EVAL_ERR        , ---          ,          )
sf( F12_SORT_ASC       , u8"⍋"          ,          )
sf( F12_SORT_DES       , u8"⍒"          ,          )
st( SPACE              , " "          ,          )
sf( F12_STILE          , u8"∣"          ,          )
qf( SVC                , u8"⎕SVC"       ,          )
qv( SVE                , u8"⎕SVE"       ,          )
qf( SVO                , u8"⎕SVO"       ,          )
qf( SVQ                , u8"⎕SVQ"       ,          )
qf( SVR                , u8"⎕SVR"       ,          )
qf( SVS                , u8"⎕SVS"       ,          )
qv( SYL                , u8"⎕SYL"       ,          )
pp( USER_SYMBOL        , ---          ,          )
qf( RE                 , u8"⎕RE"        ,          )
pp( STOP_LINE          , ---          ,          )
qf( STOP               , u8"⎕STOP"      ,          )
qf( SQL                , u8"⎕SQL"       ,          )
qf( SQL_3              , u8"⎕SQL_3"     ,          )
qf( SQL_4              , u8"⎕SQL_4"     ,          )
                                    
sf( F12_TAKE           , u8"↑"          , = 0x5401 )   // T...
qv( TC                 , u8"⎕TC"        ,          )
qf( TF                 , u8"⎕TF"        ,          )
sf( F12_TIMES          , u8"×"          ,          )
sf( F12_TRANSPOSE      , u8"⍉"          ,          )
qv( TS                 , u8"⎕TS"        ,          )
qv( TZ                 , u8"⎕TZ"        ,          )
qf( TRACE              , u8"⎕TRACE"     ,          )
                                    
qf( UCS                , u8"⎕UCS"       , = 0x5501 )   // U...
qv( UL                 , u8"⎕UL"        ,          )
sf( F2_UNEQU           , u8"≠"          ,          )
sf( F12_UNION          , u8"∪"          ,          )
pp( FUN_USER           , ---          ,          )
sf( F2_UNEQ_B          , u8"⊤≠"         ,          )
                                    
pp( VARIABLE           , ---          , = 0x5601 )   // V...
pp( VOID               , ---          ,          )
                                    
qv( WA                 , u8"⎕WA"        , = 0x5701 )   // C...
sf( F12_WITHOUT        , u8"∼"          ,          )
                                    
qv( X                  , u8"⎕X"         , = 0x5801 )   // X...
qf( XML                , u8"⎕XML"       ,          )
                                    
sf( F0_ZILDE           , u8"⍬"          , = 0x5A01 )   // Z...


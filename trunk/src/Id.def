qf( CR                 , u8"⎕CR"        ,          )
qv( CT                 , u8"⎕CT"        ,          )
st( CHI                , u8"χ"          ,          )
qf( CC                 , u8"⎕CC"        ,          )
                                    
sf( F12_DECODE         , u8"⊥"          , = 0x4401 )   // D...
st( DIAMOND            , u8"◊"          ,          )
sf( F12_DIVIDE         , u8"÷"          ,          )
qf( DL                 , u8"⎕DL"        ,          )
sf( F12_DOMINO         , u8"⌹"          ,          )
sf( F12_DROP           , u8"↓"          ,          )
qf( DLX                , u8"⎕DLX"       ,          )
                                    
qf( EA                 , u8"⎕EA"        , = 0x4501 )   // E...
sf( OPER1_EACH         , u8"¨"          ,          )
qf( EC                 , u8"⎕EC"        ,          )
sf( F12_ELEMENT        , u8"ϵ"          ,          )
qv( EM                 , u8"⎕EM"        ,          )
sf( F12_ENCODE         , u8"⊤"          ,          )
pp( END                , ---          ,          )
pp( ENDL               , ---          ,          )  // last END in line
qf( ENV                , u8"⎕ENV"       ,          )
sf( F2_EQUAL           , "="          ,          )
sf( F12_EQUIV          , u8"≡"          ,          )
pp( ERROR              , ---          ,          )
qf( ES                 , u8"⎕ES"        ,          )
st( ESCAPE             , u8"→"          ,          )
qv( ET                 , u8"⎕ET"        ,          )
qf( EX                 , u8"⎕EX"        ,          )
sf( F1_EXECUTE         , u8"⍎"          ,          )
pp( ES_EXEC            , ---          ,          )
qf( EB                 , u8"⎕EB"        ,          )
sf( F2_EQUAL_B         , u8"⊤="         ,          )
pp( ES_BRA             , ---          ,          )
pp( ES_COM             , ---          ,          )
pp( ES_ERR             , ---          ,          )
pp( ES_ESC             , ---          ,          )
                                    
qv( FC                 , u8"⎕FC"        , = 0x4601 )   // F...
sf( F2_FIND            , u8"⍷"          ,          )
pp( FIRST_TIME         , ---          ,          )
sf( F12_FORMAT         , u8"⍕"          ,          )
qf( FX                 , u8"⎕FX"        ,          )
qf( FIO                , u8"⎕FIO"       ,          )
qf( FFT                , u8"⎕FFT"       ,          )
                                    
sf( F2_GREATER         , ">"          , = 0x4701 )   // G...
qf( GTK                , u8"⎕GTK"       ,          )
st( GOTO_PC            , u8"→PC"        ,          )
                                    
sf( F2_INDEX           , u8"⌷"          , = 0x4901 )   // I...
sf( F12_INDEX_OF       , u8"⍳"          ,          )
pp( INTEGER            , ---          ,          )
pp( INVALID            , ---          ,          )
qv( IO                 , u8"⎕IO"        ,          )

   // to maintain )SAVE / )LOAD compatibility, append new items at the end
   // of their character!


// make Solaris happy
//
#ifdef ES
#undef ES
#endif

//  Id                   UCS           = Value    Macro
//-----------------------------------------------------
pp( No_ID              , ---          , = 0      )
pp( No_ID1             , ---          , = 1      )
pp( No_ID2             , ---          , = 2      )
pp( No_ID3             , ---          , = 3      )
pp( FUN                , ---          , = 4      )
pp( VAR                , ---          , = 5      )
                                    
qf( AF                 , u8"⎕AF"        , = 0x4101 )   // A...
qv( AI                 , u8"⎕AI"        ,          )
qv( ARG                , u8"⎕ARG"       ,          )
sf( F2_AND             , u8"∧"          ,          )
pp( APL_VALUE1         , ---          ,          )
pp( APL_VALUE2         , ---          ,          )
pp( APL_VALUE3         , ---          ,          )
st( ASSIGN             , u8"←"          ,          )
qf( AT                 , u8"⎕AT"        ,          )
qv( AV                 , u8"⎕AV"        ,          )
st( ALPHA              , u8"⍺"          ,          )
st( ALPHA_U            , u8"⍶"          ,          )
st( ASSIGN1            , u8"←"          ,          )
sf( F2_AND_B           , u8"⊤∧"          ,         )
pp( APL_VALUE4         , ---          ,          )
                                    
sf( F12_BINOM          , "!"          , = 0x4201 )   // B...
st( BRANCH             , u8"→"          ,          )
                                    
pp( CHARACTER          , ---          , = 0x4301 )   // C...
sf( F12_CIRCLE         , u8"○"          ,          )
st( COLON              , ":"          ,          )
sf( F12_COMMA          , ","          ,          )
sf( F12_COMMA1         , u8"⍪"          ,          )

install-dist_doc_DALYDATA: $(dist_doc_DALY_DATA)
	@$(NORMAL_INSTALL)
	@list='$(dist_doc_DALY_DATA)'; test -n "$(doc_DALYdir)" || list=; \
	if test -n "$$list"; then \
	  echo " $(MKDIR_P) '$(DESTDIR)$(doc_DALYdir)'"; \
	  $(MKDIR_P) "$(DESTDIR)$(doc_DALYdir)" || exit 1; \
	fi; \
	for p in $$list; do \
	  if test -f "$$p"; then d=; else d="$(srcdir)/"; fi; \
	  echo "$$d$$p"; \
	done | $(am__base_list) | \
	while read files; do \
	  echo " $(INSTALL_DATA) $$files '$(DESTDIR)$(doc_DALYdir)'"; \
	  $(INSTALL_DATA) $$files "$(DESTDIR)$(doc_DALYdir)" || exit $$?; \
	done


From: "Barak A. Pearlmutter" <barak+git@pearlmutter.net>
Date: Sun, 7 Jun 2026 15:17:18 +0100
Subject: generate HTML and info from texi in builddir doc/

Replace the hand-rolled info install/uninstall targets and pre-built
file approach with standard automake idioms.

Set info_TEXINFOS to the Texinfo source files (apl.texi, libapl.texi)
so automake handles .info generation and installation automatically.

Add makeinfo --html rules controlled by
AM_MAKEINFOHTMLFLAGS=--no-split to produce single-file HTML output.

Use nodist_doc_DATA for the generated HTML files so they are installed
to $(docdir) but not distributed in source tarballs.  Move the PNG
images to dist_doc_DATA.  Add CLEANFILES to remove all generated files
on make clean.

Add AM_INIT_AUTOMAKE info-in-builddir option so generated .info
files are written to the build directory rather than the source tree.
---
 configure.ac         |  2 +-
 doc/DALY/Makefile.am | 45 +++++--------------------------------
 doc/Makefile.am      | 63 +++++++++++-----------------------------------------
 3 files changed, 20 insertions(+), 90 deletions(-)

diff --git a/configure.ac b/configure.ac
index 0856575..898176d 100644
--- a/configure.ac
+++ b/configure.ac
@@ -101,7 +101,7 @@ AC_USE_SYSTEM_EXTENSIONS
 #
 # enable_dependency_tracking=no
 
-AM_INIT_AUTOMAKE([subdir-objects])
+AM_INIT_AUTOMAKE([subdir-objects info-in-builddir])
 AM_MAINTAINER_MODE([disable])
 AC_CONFIG_SRCDIR([src])
 AC_CONFIG_MACRO_DIR([m4])
diff --git a/doc/DALY/Makefile.am b/doc/DALY/Makefile.am
index a6787de..d86cbe8 100644
--- a/doc/DALY/Makefile.am
+++ b/doc/DALY/Makefile.am
@@ -1,42 +1,9 @@
+info_TEXINFOS = apl-library.texi
+MAKEINFOFLAGS = --no-split
 
-dist_doc_DALY_DATA =    apl_kbd.texi            \
-                        apl-library.info        \
-                        apl-library.texi        \
-                        apl-pkg-mgr.texi        \
-                        arg_parser.texi         \
-                        assert.texi             \
-                        cfg.texi                \
-                        cl.texi                 \
-                        date.texi               \
-                        dom.texi                \
-                        export.texi             \
-                        fdl-1.3.texi            \
-                        finance.texi            \
-                        fmt.texi                \
-                        html.texi               \
-                        import.texi             \
-                        lex1.texi               \
-                        lex.texi                \
-                        lpr.texi
+apl-library.html: apl-library.texi
+	$(MAKEINFO) --html $(MAKEINFOFLAGS) $<
 
-doc_DALYdir = $(pkglibdir)/doc/DALY
-
- NOTE: listing a file in info_TEXINFOS causes the corresponding .html file
-# to be deleted on 'make clean' That is bad for people not having a
-# $MAKEINFOHTML installed. We therefore leave info_TEXINFOS empty and instead
-# install info stuff manually below.
-#
-info_TEXINFOS =
-
-install-info-am:
-	@echo " $(MKDIR_P) $(DESTDIR)$(infodir)"
-	@       $(MKDIR_P) "$(DESTDIR)$(infodir)" || exit 1
-	@echo " $(INSTALL_DATA) $(srcdir)/apl-library.info   $(DESTDIR)$(infodir)"
-	@       $(INSTALL_DATA) $(srcdir)/apl-library.info  $(DESTDIR)$(infodir)
-
-uninstall-info-am:
-	@echo " rm -f $(DESTDIR)$(infodir)/apl.info"
-	@       rm -f $(DESTDIR)$(infodir)/apl.info
-	@echo " rm -f $(DESTDIR)$(infodir)/libapl.info"
-	@       rm -f $(DESTDIR)$(infodir)/libapl.info
+CLEANFILES = apl-library.html apl-library.info
 
+nodist_doc_DATA = apl-library.html
diff --git a/doc/Makefile.am b/doc/Makefile.am
index 17b1639..14c2f5d 100644
--- a/doc/Makefile.am
+++ b/doc/Makefile.am
@@ -7,59 +7,22 @@ SUBDIRS = DALY
 # $MAKEINFOHTML installed. We therefore leave info_TEXINFOS empty and instead
 # install info stuff manually below.
 #
-info_TEXINFOS = 
+info_TEXINFOS = apl.texi libapl.texi
 
 man1_MANS = apl.1
+HTMLFILES = apl.html libapl.html
+MAKEINFOFLAGS = --no-split
 
-# info_TEXINFOS = fails for more than one .info file. We therefore install
-# libapl.info explicitly
-#
-install-info-am:
-	@echo " $(MKDIR_P) $(DESTDIR)$(infodir)"
-	@       $(MKDIR_P) "$(DESTDIR)$(infodir)" || exit 1
-	@echo " $(INSTALL_DATA) $(srcdir)/apl.info  $(srcdir)/libapl.info $(DESTDIR)$(infodir)"
-	@       $(INSTALL_DATA) $(srcdir)/apl.info  $(srcdir)/libapl.info $(DESTDIR)$(infodir)
-
-uninstall-info-am:
-	 @echo " rm -f $(DESTDIR)$(infodir)/apl.info"
-	 @       rm -f $(DESTDIR)$(infodir)/apl.info
-	 @echo " rm -f $(DESTDIR)$(infodir)/libapl.info"
-	 @       rm -f $(DESTDIR)$(infodir)/libapl.info
-
-# apl.texi in HTML format
-#
-apl.html:   apl.texi apl-info.css
-	@$(MAKEINFOHTML) $< -o $@ --no-split --css-include=apl-info.css || touch $@
+apl.html: apl.texi apl-info.css
+	$(MAKEINFO) --html $(MAKEINFOFLAGS) --css-include=apl-info.css $<
+libapl.html: libapl.texi apl-info.css
+	$(MAKEINFO) --html $(MAKEINFOFLAGS) --css-include=apl-info.css $<
 
-# apl.texi in info format
-#
-apl.info:   apl.texi
-	@$(MAKEINFO) $< -o $@ --no-split || touch $@
+CLEANFILES = $(HTMLFILES) apl.info libapl.info
 
-# libapl.texi in HTML format
-#
-libapl.html: libapl.texi
-	$(MAKEINFOHTML) $< -o $@ --no-split || touch $@
-
-# libapl.texi in info format
-#
-libapl.info: libapl.texi
-	$(MAKEINFO) $< -o $@ --no-split || touch $@
-
-
-# NOTE that the .html version of aspl.text refers
-# to some of the files in dist_doc_DATA.
-#
-dist_doc_DATA =				\
-	apl.1					\
-	apl.texi				\
-	apl.info				\
-	apl-info.css			\
-	apl.html				\
-	libapl.texi				\
-	libapl.info				\
-	PLOT_circle.png			\
-	PLOT_zigzag.png			\
-    MX_distributions.png	\
-	libapl.html
+nodist_doc_DATA = $(HTMLFILES)
 
+dist_doc_DATA =		\
+	PLOT_circle.png	\
+	PLOT_zigzag.png	\
+	MX_distributions.png

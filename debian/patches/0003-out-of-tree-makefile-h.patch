From: "Barak A. Pearlmutter" <barak@pearlmutter.net>
Date: Sat, 6 Jun 2026 14:00:00 +0100
Subject: out-of-tree makefile.h

Add makefile.h to BUILT_SOURCES so it exists before any compilation
begins without configure.ac shenanigans.

Remove configure.ac makefile.h creation shenanigans.
---
 configure.ac    | 6 ------
 src/Makefile.am | 2 ++
 2 files changed, 2 insertions(+), 6 deletions(-)

diff --git a/configure.ac b/configure.ac
index b653b4e..08fa80b 100644
--- a/configure.ac
+++ b/configure.ac
@@ -630,12 +630,6 @@ echo "configure: creating $srcdir/src//buildtag.hh"
 rm -f $srcdir/src/buildtag.hh
 cd $srcdir/src ; . ./buildtag ; cd ..
 
-# create src/makefile.h
-#
-echo "configure: creating $srcdir/src/makefile.h"
-rm -f $srcdir/src/makefile.h
-make -C $srcdir/src makefile.h >/dev/null
-
 # remember how ./configure was called
 echo "configure: creating $srcdir/src/configure_args.cc"
 echo "extern const char * configure_args;" > $srcdir/src/configure_args.cc
diff --git a/src/Makefile.am b/src/Makefile.am
index 13ce97e..d80d0b2 100644
--- a/src/Makefile.am
+++ b/src/Makefile.am
@@ -15,6 +15,8 @@ host_os = @host_os@
 
 distcleancheck_listfile = buildtag
 
+BUILT_SOURCES = makefile.h
+
 # common means common to the apl and libapl builds
 #
 common_CXXFLAGS = -Wall -I $(srcdir)/sql $(CXX_WERROR)

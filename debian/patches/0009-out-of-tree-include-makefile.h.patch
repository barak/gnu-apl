From: "Barak A. Pearlmutter" <barak+git@pearlmutter.net>
Date: Wed, 10 Jun 2026 15:59:13 +0100
Subject: out-of-tree include makefile.h

The source tarball contains src/makefile.h with bad syntax.
With an out-of-tree build, this is being included instead of the built one.
This patch changes from #include "makefile.h" which will search
relative to the file being compiled first, to #include <makefile.h>
which will use the -I's in order which should find the out-of-tree
built one.

Long term, this file should not be included in the tarball anyway.
---
 src/NativeFunction.cc  | 2 +-
 src/UserPreferences.cc | 2 +-
 src/main.cc            | 2 +-
 3 files changed, 3 insertions(+), 3 deletions(-)

diff --git a/src/NativeFunction.cc b/src/NativeFunction.cc
index a148442..68fab89 100644
--- a/src/NativeFunction.cc
+++ b/src/NativeFunction.cc
@@ -25,7 +25,7 @@
 #include <unistd.h>
 
 #include "Error.hh"
-#include "makefile.h"
+#include <makefile.h>
 #include "NativeFunction.hh"
 #include "Symbol.hh"
 #include "Workspace.hh"
diff --git a/src/UserPreferences.cc b/src/UserPreferences.cc
index b1bbb40..6398cb0 100644
--- a/src/UserPreferences.cc
+++ b/src/UserPreferences.cc
@@ -37,7 +37,7 @@ extern const char * configure_args;
 #include "IO_Files.hh"
 #include "InputFile.hh"
 #include "LibPaths.hh"
-#include "makefile.h"
+#include <makefile.h>
 #include "Output.hh"
 #include "ScalarFunction.hh"
 #include "UserPreferences.hh"
diff --git a/src/main.cc b/src/main.cc
index 23ced68..1d7d691 100644
--- a/src/main.cc
+++ b/src/main.cc
@@ -36,7 +36,7 @@
 #include "IO_Files.hh"
 #include "LibPaths.hh"
 #include "Macro.hh"
-#include "makefile.h"
+#include <makefile.h>
 #include "Output.hh"
 #include "NativeFunction.hh"
 #include "Workspace.hh"

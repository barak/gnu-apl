-apl-library.html: apl-library.texi
-	$(MAKEINFO) $< -o $@ --no-split --html
+# apl-library.texi @includes one chapter per workspace.  Most chapters are
+# shipped as Texinfo source, but several (aparse, pw, ...) are not -- only
+# the pre-built apl-library.info, made by someone who did have them, is.
+# Reconstruct those chapters from that .info file with info-to-texi.pl so
+# the manual can be rebuilt.  These are build artifacts, not distributed.
+GENERATED_TEXI =		\
+	aparse.texi		\
+	pw.texi			\
+	pref.texi		\
+	prompt.texi		\
+	seq.texi		\
+	stack.texi		\
+	stat.texi		\
+	utf8.texi		\
+	utl.texi		\
+	wblg.texi		\
+	wp.texi			\
+	xml.texi
 
-CLEANFILES = apl-library.html apl-library.info
+$(GENERATED_TEXI): %.texi: info-to-texi.pl apl-library.info
+	perl $(srcdir)/info-to-texi.pl $* $(srcdir)/apl-library.info >$@
+
+# makeinfo must find both the committed chapters (in $(srcdir)) and the
+# reconstructed ones (written to the build directory).
+AM_MAKEINFOFLAGS = -I $(srcdir) -I .
+
+# Reconstruct the missing chapters before the manual is formatted.
+BUILT_SOURCES = $(GENERATED_TEXI)
+apl-library.info: $(GENERATED_TEXI)
+
+apl-library.html: apl-library.texi $(GENERATED_TEXI)
+	$(MAKEINFO) $(AM_MAKEINFOFLAGS) $< -o $@ --no-split --html
+
+CLEANFILES = apl-library.html apl-library.info $(GENERATED_TEXI)
 
 nodist_doc_DATA = apl-library.html
+
+EXTRA_DIST = info-to-texi.pl

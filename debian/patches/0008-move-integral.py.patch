From: "Barak A. Pearlmutter" <barak+git@pearlmutter.net>
Date: Mon, 22 Jun 2026 15:31:24 +0100
Subject: move integral.py

support file belongs in /usr/share/apl/ not /usr/bin/.
---
 configure.ac      |  2 ++
 src/Makefile.am   |  8 +++++---
 src/PythonPipe.cc | 15 ++++++++-------
 3 files changed, 15 insertions(+), 10 deletions(-)

diff --git a/configure.ac b/configure.ac
index 898176d..8a91ddb 100644
--- a/configure.ac
+++ b/configure.ac
@@ -935,6 +935,8 @@ AC_DEFINE_UNQUOTED(apl_DIR__prefix,      "$apl_prefix",      [--prefix]        )
 AC_DEFINE_UNQUOTED(apl_DIR__sysconf,     "$apl_sysconfdir",  [--sysconfdir])
 AC_DEFINE_UNQUOTED(apl_DIR__pkglib,      "$apl_libdir/apl",
                    [installation directory for GNU APL libraries])
+AC_DEFINE_UNQUOTED(apl_DIR__pkgdata,     "$apl_datarootdir/apl",
+                   [installation directory for GNU APL data files])
 
 if test -n "$SOURCE_DATE_EPOCH"
 then   # reproducible build
diff --git a/src/Makefile.am b/src/Makefile.am
index 00bf2ab..9795f23 100644
--- a/src/Makefile.am
+++ b/src/Makefile.am
@@ -2,9 +2,11 @@
 # NOTE: without 'no-dependencies' make target distclean won't work.
 # AUTOMAKE_OPTIONS = no-dependencies
 
-dist_noinst_SCRIPTS = integral.py
-dist_SCRIPTS = integral.py
-distdir = ${bindir}
+# integral.py is a support script that ⌹ (matrix divide, see Bif_F12_DOMINO.cc)
+# pipes through python3.  It is data, not an executable, so it is installed
+# below $(pkgdatadir) rather than in $(bindir).  PythonPipe.cc locates it via
+# apl_DIR__pkgdata (from config.h, i.e. ./configure --datarootdir).
+dist_pkgdata_DATA = integral.py
 
 EXTRA_DIRS =
 if ! apl_TARGET_ANDROID
diff --git a/src/PythonPipe.cc b/src/PythonPipe.cc
index c83f158..5a209b5 100644
--- a/src/PythonPipe.cc
+++ b/src/PythonPipe.cc
@@ -27,7 +27,6 @@
 #include <netinet/in.h>
 
 #include "Error_macros.hh"
-#include "LibPaths.hh"
 #include "PythonPipe.hh"
 
 //============================================================================
@@ -36,14 +35,16 @@ PythonPipe::PythonPipe(const char * script)
     pid(-1),
     fd(-1)
 {
-   // check that script is readable. We expect in in the current directory, or
-   // else in APL_bin_path.
+   // check that script is readable. We expect it in the current directory
+   // (e.g. when running from the build tree), or else in $(pkgdatadir), where
+   // it is installed (dist_pkgdata_DATA in src/Makefile.am).
    //
 UTF8_string argv1_utf;
    {
-     const char * bin_dir = LibPaths::get_APL_bin_path();
-     UTF8_string path1("./");      // current directory
-     UTF8_string path2(bin_dir);   // where apl shll be installed
+     const char * data_dir = apl_DIR__pkgdata;
+     UTF8_string path1("./");          // current directory
+     UTF8_string path2(data_dir);      // where integral.py is installed
+     path2 << "/";
      path1 << script;
      path2 << script;
      if      (access(path1.c_str(), R_OK) == 0)   argv1_utf = path1;
@@ -51,7 +52,7 @@ UTF8_string argv1_utf;
      else
         {
           MORE_ERROR() << "No python script '" << script
-                       << "' in the current directory or in " << bin_dir;
+                       << "' in the current directory or in " << data_dir;
           DOMAIN_ERROR;
         }
    }

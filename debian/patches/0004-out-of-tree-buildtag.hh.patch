From: "Barak A. Pearlmutter" <barak+git@pearlmutter.net>
Date: Tue, 9 Jun 2026 14:19:07 +0100
Subject: out-of-tree buildtag.hh

---
 configure.ac       | 28 ++++++++++++++++++++++------
 src/Makefile.am    |  4 +---
 src/buildtag       | 52 ----------------------------------------------------
 src/buildtag.hh.in |  3 +++
 4 files changed, 26 insertions(+), 61 deletions(-)
 delete mode 100644 src/buildtag
 create mode 100644 src/buildtag.hh.in

diff --git a/configure.ac b/configure.ac
index 08fa80b..6f0c5a7 100644
--- a/configure.ac
+++ b/configure.ac
@@ -4,6 +4,27 @@
 AC_PREREQ([2.65])
 AC_INIT([GNU APL], [1.8], [bug-apl@gnu.org])
 configure_options="$0 $*"
+CONFIGURE_ARGS="$configure_options"
+AC_SUBST([CONFIGURE_ARGS])
+
+# Build-tag components substituted into src/buildtag.hh.in by config.status.
+# Computed here (before AC_OUTPUT) so the values are captured at configure time.
+SVNINFO=$(svnversion 2>/dev/null || echo "")
+ARCHIVE_SVNINFO=$(svn info "$srcdir/src/Archive.cc" 2>/dev/null \
+    | awk -F: '/Last Changed Rev/{gsub(/ /,"",$2); print $2}')
+if test -n "$SOURCE_DATE_EPOCH"; then
+    BUILD_DATE=$(date -u "+%F %R:%S %Z" --date=@$SOURCE_DATE_EPOCH)
+    BUILD_OS=""
+else
+    BUILD_DATE=$(date -u "+%F %R:%S %Z")
+    BUILD_OS=$(uname -s -r -m)
+fi
+CONFIGURE_OPTS="$configure_options"
+AC_SUBST([SVNINFO])
+AC_SUBST([ARCHIVE_SVNINFO])
+AC_SUBST([BUILD_DATE])
+AC_SUBST([BUILD_OS])
+AC_SUBST([CONFIGURE_OPTS])
 AC_PREFIX_DEFAULT( /usr/local )
 AC_CONFIG_AUX_DIR([.])
 AC_USE_SYSTEM_EXTENSIONS
@@ -367,6 +388,7 @@ AC_CONFIG_FILES([Makefile
                  rpm/Makefile
                  rpm/apl.spec
                  src/Makefile
+                 src/buildtag.hh
                  src/APs/Makefile
                  src/Gtk/Makefile
                  src/emacs_mode/Makefile
@@ -624,12 +646,6 @@ AC_OUTPUT
 
 echo
 
-# create src/buildtag.hh
-#
-echo "configure: creating $srcdir/src//buildtag.hh"
-rm -f $srcdir/src/buildtag.hh
-cd $srcdir/src ; . ./buildtag ; cd ..
-
 # remember how ./configure was called
 echo "configure: creating $srcdir/src/configure_args.cc"
 echo "extern const char * configure_args;" > $srcdir/src/configure_args.cc
